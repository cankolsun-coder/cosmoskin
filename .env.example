# COSMOSKIN — Cloudflare Pages / Wrangler environment template
# Copy to your shell or Cloudflare Pages Variables. Never commit real secrets.

# --- Supabase (required) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_TIMEOUT_MS=12000

# Public/browser aliases (optional; public-config.js falls back to SUPABASE_*)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
COSMOSKIN_SUPABASE_URL=
COSMOSKIN_PUBLIC_SUPABASE_ANON_KEY=

# --- Site URLs ---
PUBLIC_SITE_URL=https://www.cosmoskin.com.tr
SITE_URL=https://www.cosmoskin.com.tr
COSMOSKIN_SITE_URL=https://www.cosmoskin.com.tr

# --- Admin auth (server-only secrets) ---
ADMIN_TOKEN=replace-with-long-random-admin-token
ADMIN_SESSION_SECRET=replace-with-long-random-admin-session-secret
ADMIN_SESSION_TTL_SECONDS=1800
ADMIN_ALLOW_LEGACY_TOKEN=false
REQUIRE_CLOUDFLARE_ACCESS=true

# --- İyzico payments ---
IYZICO_API_KEY=replace-with-iyzico-api-key
IYZICO_SECRET_KEY=replace-with-iyzico-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_TIMEOUT_MS=15000

# --- Brevo / email ---
BREVO_API_KEY=replace-with-brevo-api-key
BREVO_SENDER_EMAIL=siparis@cosmoskin.com.tr
BREVO_SENDER_NAME=COSMOSKIN
ORDER_FROM_EMAIL=siparis@cosmoskin.com.tr
ORDER_SENDER_NAME=COSMOSKIN
CONTACT_FROM_EMAIL=destek@cosmoskin.com.tr
CONTACT_TO_EMAIL=destek@cosmoskin.com.tr
PARTNERSHIP_TO_EMAIL=partnership@cosmoskin.com.tr
NEWSLETTER_FROM_EMAIL=newsletter@cosmoskin.com.tr
NEWSLETTER_SENDER_NAME=COSMOSKIN Journal

# Optional Brevo list IDs (numeric)
BREVO_LIST_CUSTOMERS_ID=
BREVO_LIST_ROUTINE_ID=
BREVO_LIST_REORDER_ID=
BREVO_LIST_HIGH_VALUE_ID=
BREVO_LIST_CLEANSE_ID=
BREVO_LIST_HYDRATE_ID=
BREVO_LIST_CARE_ID=
BREVO_LIST_TREAT_ID=
BREVO_LIST_PROTECT_ID=

# --- Cloudflare Turnstile (contact / spam protection) ---
TURNSTILE_SITE_KEY=replace-with-turnstile-site-key
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret-key

# --- Cron / batch jobs ---
CRON_SECRET=replace-with-cron-secret
REMINDER_CRON_SECRET=replace-with-reminder-cron-secret
CRON_BATCH_LIMIT=200
EFT_RESERVATION_MINUTES=1440

# --- E-archive / invoice (optional) ---
EARCHIVE_PROVIDER=manual
QNB_API_BASE_URL=
QNB_CLIENT_ID=
QNB_CLIENT_SECRET=

# --- DHL shipping (optional) ---
DHL_API_BASE_URL=
DHL_API_KEY=
DHL_CLIENT_ID=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_WEBHOOK_SECRET=

# --- Local / QA scripts only (not production Pages vars) ---
IYZICO_CALLBACK_URL=
IYZICO_TEST_TOKEN=
ALLOW_DESTRUCTIVE_TEST=
TEST_INVENTORY_SLUG=
