{
  "ci": {
    "collect": {
      "startServerCommand": "python3 -m http.server 4173 --directory .",
      "startServerReadyPattern": "Serving HTTP",
      "url": [
        "http://127.0.0.1:4173/index.html",
        "http://127.0.0.1:4173/collections/bestsellers.html",
        "http://127.0.0.1:4173/brands/cosrx.html",
        "http://127.0.0.1:4173/products/cosrx-low-ph-good-morning-gel-cleanser.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.65
          }
        ],
        "categories:accessibility": [
          "warn",
          {
            "minScore": 0.85
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.80
          }
        ],
        "categories:seo": [
          "warn",
          {
            "minScore": 0.90
          }
        ],
        "largest-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 4000
          }
        ],
        "cumulative-layout-shift": [
          "warn",
          {
            "maxNumericValue": 0.15
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lighthouse-reports"
    }
  }
}

